<Window x:Class="VideohostingPanel.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VideohostingPanel"
        Title="Вход в систему"
        Width="450"
        Height="530"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Classes/Other/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="LoginButtonStyle" BasedOn="{StaticResource BaseButtonStyle}" TargetType="Button">
                <Setter Property="Content" Value="Войти"/>
                <Setter Property="Margin" Value="30,20,30,0"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <!-- Фон с градиентом и паттерном -->
        <Grid.Background>
            <RadialGradientBrush Center="0.8,0.2" RadiusX="0.8" RadiusY="0.8">
                <GradientStop Color="#2D0B4A" Offset="0"/>
                <GradientStop Color="#0A0A0A" Offset="1"/>
            </RadialGradientBrush>
        </Grid.Background>

        <!-- Декоративный паттерн -->
        <Rectangle Opacity="0.02">
            <Rectangle.Fill>
                <DrawingBrush Viewport="0,0,20,20" ViewportUnits="Absolute" TileMode="Tile">
                    <DrawingBrush.Drawing>
                        <GeometryDrawing Brush="White">
                            <GeometryDrawing.Geometry>
                                <GeometryGroup>
                                    <LineGeometry StartPoint="0,0" EndPoint="20,20"/>
                                    <LineGeometry StartPoint="20,0" EndPoint="0,20"/>
                                </GeometryGroup>
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Основной контейнер -->
        <Border Margin="20"
                Background="{StaticResource DarkSecondaryBrush}"
                CornerRadius="20"
                BorderBrush="{StaticResource PrimaryPurpleBrush}"
                BorderThickness="1"
                Opacity="0.95">

            <Grid Margin="0,0,0,-1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Заголовок -->
                <Border Grid.Row="0"
                        Background="{StaticResource HeaderGradient}"
                        CornerRadius="20,20,0,0"
                        Height="120">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="ВидеоХостинг"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Панель администратора"
                                   FontSize="16"
                                   Foreground="White"
                                   Opacity="0.9"
                                   HorizontalAlignment="Center"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Форма входа -->
                <StackPanel Grid.Row="1" Margin="30,30,30,20">
                    <!-- Поле логина -->
                    <TextBlock Text="ЛОГИН"
                              Style="{StaticResource SubHeaderStyle}"
                              Margin="0,0,0,5"
                              FontSize="12"/>

                    <TextBox x:Name="LoginTextBox"
                            Style="{StaticResource BaseTextBoxStyle}"
                            Margin="0,0,0,20"/>

                    <!-- Поле пароля -->
                    <TextBlock Text="ПАРОЛЬ"
                              Style="{StaticResource SubHeaderStyle}"
                              Margin="0,0,0,5"
                              FontSize="12"/>

                    <PasswordBox x:Name="PasswordBox"
                                Style="{StaticResource BasePasswordBoxStyle}"
                                Margin="0,0,0,30"/>

                    <!-- Кнопка входа -->
                    <Button x:Name="LoginButton"
                           Style="{StaticResource LoginButtonStyle}"
                           Height="50"
                           Click="LoginButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ВОЙТИ" FontSize="16" Margin="0,0,10,0"/>
                            <Path Data="M10,5 L15,10 L10,15"
                                  Stroke="White"
                                  StrokeThickness="2"
                                  Fill="Transparent"/>
                        </StackPanel>
                    </Button>

                    <!-- Сообщение об ошибке (скрыто по умолчанию) -->
                    <Border x:Name="ErrorMessageBorder"
                            Background="#33FF0000"
                            CornerRadius="10"
                            BorderBrush="{StaticResource PrimaryRedBrush}"
                            BorderThickness="1"
                            Margin="0,20,0,0"
                            Visibility="Collapsed">
                        <TextBlock x:Name="ErrorMessageText"
                                  Text="Неверный логин или пароль"
                                  Foreground="#FFFF8888"
                                  Padding="15,10"
                                  TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Кнопка закрытия -->
        <Button x:Name="CloseButton"
                Width="30"
                Height="30"
                Background="Transparent"
                BorderThickness="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,10,10,0"
                Cursor="Hand"
                Click="CloseButton_Click">
            <Button.Content>
                <Path Data="M0,0 L10,10 M10,0 L0,10"
                      Stroke="White"
                      StrokeThickness="2"
                      Width="12"
                      Height="12"/>
            </Button.Content>
        </Button>
    </Grid>
</Window>