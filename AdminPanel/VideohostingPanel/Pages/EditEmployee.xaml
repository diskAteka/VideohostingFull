<Page x:Class="VideohostingPanel.Pages.EditEmployee"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="EditEmployeePage"
      MinWidth="1200" MinHeight="800"
      Background="Transparent">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/VideohostingPanel;component/Classes/Other/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="SaveButtonStyle" BasedOn="{StaticResource BaseButtonStyle}" TargetType="Button">
                <Setter Property="Content" Value="Сохранить"/>
                <Setter Property="Margin" Value="10"/>
                <Setter Property="Width" Value="120"/>
            </Style>

            <Style x:Key="CancelButtonStyle" BasedOn="{StaticResource BaseButtonStyle}" TargetType="Button">
                <Setter Property="Content" Value="Отмена"/>
                <Setter Property="Background" Value="{StaticResource DarkTertiaryBrush}"/>
                <Setter Property="Margin" Value="10"/>
                <Setter Property="Width" Value="120"/>
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <!-- Прозрачный градиентный фон для анимаций переходов -->
        <Grid x:Name="BackgroundGrid" Opacity="0.95">
            <Grid.Background>
                <RadialGradientBrush Center="0.8,0.2" RadiusX="1.2" RadiusY="1.2">
                    <GradientStop Color="#2D0B4A" Offset="0"/>
                    <GradientStop Color="#0A0A0A" Offset="1"/>
                </RadialGradientBrush>
            </Grid.Background>

            <!-- Декоративный паттерн -->
            <Rectangle Opacity="0.02">
                <Rectangle.Fill>
                    <DrawingBrush Viewport="0,0,20,20" ViewportUnits="Absolute" TileMode="Tile">
                        <DrawingBrush.Drawing>
                            <GeometryDrawing Brush="White">
                                <GeometryDrawing.Geometry>
                                    <GeometryGroup>
                                        <LineGeometry StartPoint="0,0" EndPoint="20,20"/>
                                        <LineGeometry StartPoint="20,0" EndPoint="0,20"/>
                                    </GeometryGroup>
                                </GeometryDrawing.Geometry>
                            </GeometryDrawing>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Grid>

        <!-- Основной контент с отступами -->
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Кнопка назад -->
            <Border Grid.Row="0"
                    Background="Transparent"
                    Margin="0,0,0,10"
                    HorizontalAlignment="Left">
                <Button x:Name="BackButton"
                        Style="{StaticResource BaseButtonStyle}"
                        Background="{StaticResource DarkBackgroundBrush}"
                        Width="100"
                        Height="35"
                        FontSize="12">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M0,10 L10,0 L10,20 Z"
                              Fill="{StaticResource PrimaryPurpleBrush}"
                              Width="10"
                              Height="10"
                              Margin="0,0,5,0"/>
                        <TextBlock Text="Назад"/>
                    </StackPanel>
                </Button>
            </Border>

            <!-- Контейнер для формы -->
            <Border Grid.Row="1"
                    Background="{StaticResource DarkSecondaryBrush}"
                    CornerRadius="20"
                    BorderBrush="{StaticResource PrimaryPurpleBrush}"
                    BorderThickness="1">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок -->
                    <Border Grid.Row="0"
                            Background="{StaticResource HeaderGradient}"
                            CornerRadius="20,20,0,0"
                            Height="70">
                        <TextBlock Text="Редактирование сотрудника"
                                  FontSize="24"
                                  FontWeight="Bold"
                                  Foreground="White"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>

                    <!-- Форма редактирования -->
                    <ScrollViewer Grid.Row="1"
                                 Style="{StaticResource BaseScrollViewerStyle}"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Disabled"
                                 Margin="20">
                        <StackPanel>

                            <!-- ID (только для чтения) -->
                            <TextBlock Text="ID сотрудника"
                                      Style="{StaticResource SubHeaderStyle}"
                                      Margin="0,0,0,5"
                                      FontSize="12"/>
                            <TextBox x:Name="P_Id"
                                    Text="1"
                                    Style="{StaticResource BaseTextBoxStyle}"
                                    IsReadOnly="True"
                                    Background="{StaticResource DarkBackgroundBrush}"
                                    Margin="0,0,0,15"/>

                            <!-- Имя пользователя -->
                            <TextBlock Text="Имя пользователя *"
                                      Style="{StaticResource SubHeaderStyle}"
                                      Margin="0,0,0,5"
                                      FontSize="12"/>
                            <TextBox x:Name="P_UserName"
                                    Text="admin"
                                    Style="{StaticResource BaseTextBoxStyle}"
                                    Margin="0,0,0,15"/>

                            <!-- Пароль (в открытом виде) -->
                            <TextBlock Text="Пароль *"
                                      Style="{StaticResource SubHeaderStyle}"
                                      Margin="0,0,0,5"
                                      FontSize="12"/>
                            <PasswordBox x:Name="P_Password"
                                        Style="{StaticResource BasePasswordBoxStyle}"
                                        Password="admin123"
                                        Margin="0,0,0,15"/>

                            <!-- Роль -->
                            <TextBlock Text="Роль *"
                                      Style="{StaticResource SubHeaderStyle}"
                                      Margin="0,0,0,5"
                                      FontSize="12"/>
                            <ComboBox x:Name="P_RoleComboBox"
                                     Style="{StaticResource BaseComboBoxStyle}"
                                     Margin="0,0,0,15"
                                     SelectedIndex="0">
                                <ComboBoxItem Content="Администратор"/>
                                <ComboBoxItem Content="Верификатор"/>
                            </ComboBox>

                            <!-- Кнопка удалить - без подложки, как часть контента -->
                            <Button x:Name="P_DeleteButton"
                                    Click="DeleteRecord"
                                   Content="УДАЛИТЬ СОТРУДНИКА"
                                   Background="#66FF0000"
                                   Style="{StaticResource BaseButtonStyle}"
                                   Height="45"
                                   Margin="0,20,0,0"
                                   HorizontalAlignment="Center"
                                   Width="250"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Кнопки действий -->
                    <Border Grid.Row="2"
                            Background="{StaticResource DarkTertiaryBrush}"
                            CornerRadius="0,0,20,20"
                            Padding="20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="1"
                                   x:Name="P_SaveButton"
                                   Style="{StaticResource SaveButtonStyle}"
                                   Margin="10"/>
                            <Button Grid.Column="2" 
                                   x:Name="P_CancelButton"
                                   Style="{StaticResource CancelButtonStyle}"
                                    Background="{StaticResource DarkBackgroundBrush}"
                                   Margin="10"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Нижний отступ для баланса -->
            <Border Grid.Row="2" Height="10" Background="Transparent"/>
        </Grid>
    </Grid>
</Page>