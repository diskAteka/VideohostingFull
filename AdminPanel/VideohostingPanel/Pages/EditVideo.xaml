<Page x:Class="VideohostingPanel.Pages.EditVideo"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d" d:DesignWidth="1200"
      Title="EditVideoPage"
      MinWidth="1200" MinHeight="800"
      Background="Transparent" Height="1318">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/VideohostingPanel;component/Classes/Other/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="SaveButtonStyle" BasedOn="{StaticResource BaseButtonStyle}" TargetType="Button">
                <Setter Property="Content" Value="Сохранить"/>
                <Setter Property="Margin" Value="10"/>
                <Setter Property="Width" Value="120"/>
            </Style>

            <Style x:Key="CancelButtonStyle" BasedOn="{StaticResource BaseButtonStyle}" TargetType="Button">
                <Setter Property="Content" Value="Отмена"/>
                <Setter Property="Background" Value="{StaticResource DarkTertiaryBrush}"/>
                <Setter Property="Margin" Value="10"/>
                <Setter Property="Width" Value="120"/>
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <!-- Прозрачный градиентный фон для анимаций переходов -->
        <Grid x:Name="BackgroundGrid" Opacity="0.95">
            <Grid.Background>
                <RadialGradientBrush Center="0.8,0.2" RadiusX="1.2" RadiusY="1.2">
                    <GradientStop Color="#2D0B4A" Offset="0"/>
                    <GradientStop Color="#0A0A0A" Offset="1"/>
                </RadialGradientBrush>
            </Grid.Background>

            <!-- Декоративный паттерн -->
            <Rectangle Opacity="0.02">
                <Rectangle.Fill>
                    <DrawingBrush Viewport="0,0,20,20" ViewportUnits="Absolute" TileMode="Tile">
                        <DrawingBrush.Drawing>
                            <GeometryDrawing Brush="White">
                                <GeometryDrawing.Geometry>
                                    <GeometryGroup>
                                        <LineGeometry StartPoint="0,0" EndPoint="20,20"/>
                                        <LineGeometry StartPoint="20,0" EndPoint="0,20"/>
                                    </GeometryGroup>
                                </GeometryDrawing.Geometry>
                            </GeometryDrawing>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Grid>

        <!-- Основной контент с отступами -->
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Кнопка назад -->
            <Border Grid.Row="0"
                    Background="Transparent"
                    Margin="0,0,0,10"
                    HorizontalAlignment="Left">
                <Button x:Name="BackButton"
                        Style="{StaticResource BaseButtonStyle}"
                        Background="{StaticResource DarkBackgroundBrush}"
                        Width="100"
                        Height="35"
                        FontSize="12">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M0,10 L10,0 L10,20 Z"
                              Fill="{StaticResource PrimaryPurpleBrush}"
                              Width="10"
                              Height="10"
                              Margin="0,0,5,0"/>
                        <TextBlock Text="Назад"/>
                    </StackPanel>
                </Button>
            </Border>

            <!-- Контейнер для формы -->
            <Border Grid.Row="1"
                    Background="{StaticResource DarkSecondaryBrush}"
                    CornerRadius="20"
                    BorderBrush="{StaticResource PrimaryPurpleBrush}"
                    BorderThickness="1">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок -->
                    <Border Grid.Row="0"
                            Background="{StaticResource HeaderGradient}"
                            CornerRadius="20,20,0,0"
                            Height="70">
                        <TextBlock Text="Редактирование видео"
                                  FontSize="24"
                                  FontWeight="Bold"
                                  Foreground="White"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>

                    <!-- Форма редактирования -->
                    <ScrollViewer Grid.Row="1"
                                 Style="{StaticResource BaseScrollViewerStyle}"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Disabled"
                                 Margin="20">
                        <StackPanel>

                            <!-- ID (только для чтения) -->
                            <TextBlock Text="ID"
                                      Style="{StaticResource SubHeaderStyle}"
                                      Margin="0,0,0,5"
                                      FontSize="12"/>
                            <TextBox x:Name="P_Id"
                                    Text="123"
                                    Style="{StaticResource BaseTextBoxStyle}"
                                    IsReadOnly="True"
                                    Background="{StaticResource DarkBackgroundBrush}"
                                    Margin="0,0,0,15"/>

                            <!-- Название видео -->
                            <TextBlock Text="Название видео *"
                                      Style="{StaticResource SubHeaderStyle}"
                                      Margin="0,0,0,5"
                                      FontSize="12"/>
                            <TextBox x:Name="P_VideoNameTextBox"
                                    Text="Пример названия видео"
                                    Style="{StaticResource BaseTextBoxStyle}"
                                    Margin="0,0,0,15"/>

                            <!-- Описание -->
                            <TextBlock Text="Описание"
                                      Style="{StaticResource SubHeaderStyle}"
                                      Margin="0,0,0,5"
                                      FontSize="12"/>
                            <TextBox x:Name="P_DescriptionTextBox"
                                    Text="Подробное описание видео контента..."
                                    Style="{StaticResource BaseTextBoxStyle}"
                                    Height="100"
                                    TextWrapping="Wrap"
                                    AcceptsReturn="True"
                                    Margin="0,0,0,15"/>

                            <!-- Автор с поиском по ID -->
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Заголовок -->
                                <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                                           Text="Автор (ID)"
                                           Style="{StaticResource SubHeaderStyle}"
                                           Margin="0,0,0,5"
                                           FontSize="12"/>

                                <!-- ComboBox с авторами -->
                                <ComboBox Grid.Row="1" Grid.Column="0"
                                         x:Name="P_AuthorComboBox"
                                         Style="{StaticResource BaseComboBoxStyle}"
                                         Margin="0,0,10,0">
                                    <ComboBoxItem Content="Иван Иванов (ID: 1)" IsSelected="True"/>
                                    <ComboBoxItem Content="Петр Петров (ID: 2)"/>
                                </ComboBox>

                                <!-- Поиск по ID автора -->
                                <Border Grid.Row="1" Grid.Column="1"
                                        Background="{StaticResource DarkBackgroundBrush}"
                                        CornerRadius="14"
                                        BorderBrush="{StaticResource PrimaryPurpleBrush}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="ID:"
                                                   FontSize="14"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0,5,0"/>

                                        <TextBox x:Name="P_AuthorSearchIdTextBox"
                                                 Grid.Column="1"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                 FontSize="14"
                                                 VerticalAlignment="Center"
                                                 Padding="5,0"
                                                 MaxLength="10"/>

                                        <Button x:Name="P_SearchAuthorByIdButton"
                                                Grid.Column="2"
                                                Content="Найти"
                                                Style="{StaticResource BaseButtonStyle}"
                                                Height="35"
                                                Width="60"
                                                Margin="0,0,5,0"
                                                FontSize="11"/>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- Пути к файлам -->
                            <TextBlock Text="Ссылка на видео"
                                      Style="{StaticResource SubHeaderStyle}"
                                      Margin="0,0,0,5"
                                      FontSize="12"/>
                            <TextBox x:Name="P_LinkTextBox"
                                    Text="/videos/123.mp4"
                                    Style="{StaticResource BaseTextBoxStyle}"
                                    Margin="0,0,0,15"/>

                            <TextBlock Text="Постер"
                                      Style="{StaticResource SubHeaderStyle}"
                                      Margin="0,0,0,5"
                                      FontSize="12"/>
                            <TextBox x:Name="P_PosterTextBox"
                                    Text="/posters/123.jpg"
                                    Style="{StaticResource BaseTextBoxStyle}"
                                    Margin="0,0,0,15"/>

                            <!-- Статус верификации -->
                            <TextBlock Text="Статус верификации"
                                      Style="{StaticResource SubHeaderStyle}"
                                      Margin="0,0,0,5"
                                      FontSize="12"/>
                            <ComboBox x:Name="P_VerificationComboBox"
                                     Style="{StaticResource BaseComboBoxStyle}"
                                     Margin="0,0,0,15">
                                <ComboBoxItem Content="Не верифицировано"/>
                                <ComboBoxItem Content="Верифицировано" IsSelected="True"/>
                            </ComboBox>

                            <!-- Статистика (только для чтения) -->
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Просмотры"
                                              FontSize="11"
                                              Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBox x:Name="P_ViewsCount"
                                            Text="1234"
                                            Style="{StaticResource BaseTextBoxStyle}"
                                            Height="40"
                                            Margin="0,5,5,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Лайки"
                                              FontSize="11"
                                              Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBox x:Name="P_LikesCount"
                                            Text="56"
                                            Style="{StaticResource BaseTextBoxStyle}"
                                            Height="40"
                                            Margin="5,5,5,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Дизлайки"
                                              FontSize="11"
                                              Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBox x:Name="P_DislikesCount"
                                            Text="3"
                                            Style="{StaticResource BaseTextBoxStyle}"
                                            Height="40"
                                            Margin="5,5,0,0"/>
                                </StackPanel>
                            </Grid>

                            <!-- Даты (только для чтения) -->
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Дата загрузки"
                                              FontSize="11"
                                              Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBox x:Name="P_UploadDate"
                                            Text="01.01.2024 15:30"
                                            Style="{StaticResource BaseTextBoxStyle}"
                                            IsReadOnly="True"
                                            Background="{StaticResource DarkBackgroundBrush}"
                                            Height="40"
                                            Margin="0,5,5,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Последнее изменение"
                                              FontSize="11"
                                              Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBox x:Name="P_LastModifiedDate"
                                            Text="15.02.2024 10:15"
                                            Style="{StaticResource BaseTextBoxStyle}"
                                            IsReadOnly="True"
                                            Background="{StaticResource DarkBackgroundBrush}"
                                            Height="40"
                                            Margin="5,5,0,0"/>
                                </StackPanel>
                            </Grid>

                            <!-- Кнопка удалить - без подложки, как часть контента -->
                            <Button x:Name="P_DeleteButton"
                                    Click="DeleteVideo"
                                   Content="УДАЛИТЬ ВИДЕО"
                                   Background="#66FF0000"
                                   Style="{StaticResource BaseButtonStyle}"
                                   Height="45"
                                   Margin="0,20,0,0"
                                   HorizontalAlignment="Center"
                                   Width="250"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Кнопки действий -->
                    <Border Grid.Row="2"
                            Background="{StaticResource DarkTertiaryBrush}"
                            CornerRadius="0,0,20,20"
                            Padding="20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="1"
                                   x:Name="P_SaveButton"
                                   Style="{StaticResource SaveButtonStyle}"
                                   Margin="10"/>
                            <Button Grid.Column="2"
                                   x:Name="P_CancelButton"
                                   Style="{StaticResource CancelButtonStyle}"
                                   Margin="10"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Нижний отступ для баланса -->
            <Border Grid.Row="2" Height="10" Background="Transparent"/>
        </Grid>
    </Grid>
</Page>