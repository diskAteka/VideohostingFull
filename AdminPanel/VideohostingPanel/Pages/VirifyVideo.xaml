<Page x:Class="VideohostingPanel.Pages.VerifyVideo"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Microsoft.EntityFrameworkCore.Storage.ValueConversion;assembly=Microsoft.EntityFrameworkCore"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="VerifyVideo">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/VideohostingPanel;component/Classes/Other/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>



            <!-- Конвертер для времени -->
            <local:TimeSpanToStringConverter x:Key="TimeSpanToStringConverter"/>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <!-- Фон -->
        <Grid.Background>
            <RadialGradientBrush Center="0.8,0.2" RadiusX="0.8" RadiusY="0.8">
                <GradientStop Color="#2D0B4A" Offset="0"/>
                <GradientStop Color="#0A0A0A" Offset="1"/>
            </RadialGradientBrush>
        </Grid.Background>

        <Border Margin="20"
                Background="{StaticResource DarkSecondaryBrush}"
                CornerRadius="20"
                BorderBrush="{StaticResource PrimaryPurpleBrush}"
                BorderThickness="1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок -->
                <Border Grid.Row="0"
                        Background="{StaticResource HeaderGradient}"
                        CornerRadius="20,20,0,0"
                        Height="70">
                    <Grid>
                        <TextBlock Text="Верификация видео"
                                  FontSize="24"
                                  FontWeight="Bold"
                                  Foreground="White"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>

                        <!-- Кнопка закрытия -->
                        <Button x:Name="CloseButton"
                                Width="30"
                                Height="30"
                                Background="Transparent"
                                BorderThickness="0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,20,0"
                                Cursor="Hand">
                            <Path Data="M0,0 L15,15 M15,0 L0,15"
                                  Stroke="White"
                                  StrokeThickness="2"
                                  Width="12"
                                  Height="12"/>
                            <Button.Triggers>
                                <EventTrigger RoutedEvent="Button.MouseEnter">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Duration="0:0:0.2"
                                                           Storyboard.TargetProperty="Opacity"
                                                           To="0.8"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                                <EventTrigger RoutedEvent="Button.MouseLeave">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Duration="0:0:0.2"
                                                           Storyboard.TargetProperty="Opacity"
                                                           To="1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Button.Triggers>
                        </Button>
                    </Grid>
                </Border>

                <!-- Основной контент -->
                <ScrollViewer Grid.Row="1"
                             Style="{StaticResource BaseScrollViewerStyle}"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled">

                    <StackPanel Margin="20">

                        <!-- Информация о видео -->
                        <Border Background="{StaticResource DarkTertiaryBrush}"
                                CornerRadius="15"
                                Padding="20"
                                Margin="0,0,0,20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Постер (заглушка) -->
                                <Border Grid.Row="0"
                                        Grid.RowSpan="2"
                                        Grid.Column="0"
                                        Width="120"
                                        Height="90"
                                        Background="{StaticResource DarkBackgroundBrush}"
                                        CornerRadius="10"
                                        Margin="0,0,20,0">
                                    <Path Data="M0,0 L60,0 L60,40 L0,40 Z M10,10 L50,10 L50,30 L10,30 Z"
                                          Fill="{StaticResource PrimaryRedBrush}"
                                          Width="50"
                                          Height="30"
                                          Stretch="Uniform"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                </Border>

                                <!-- Название и автор -->
                                <StackPanel Grid.Row="0"
                                           Grid.Column="1"
                                           Margin="0,0,0,10">
                                    <TextBlock x:Name="VideoNameText"
                                              Text="Удивительное путешествие по горам"
                                              FontSize="22"
                                              FontWeight="Bold"
                                              Foreground="{StaticResource TextPrimaryBrush}"
                                              TextWrapping="Wrap"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <TextBlock Text="Автор:"
                                                  FontSize="14"
                                                  Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock x:Name="AuthorNameText"
                                                  Text="Иван Иванов"
                                                  FontSize="14"
                                                  FontWeight="Bold"
                                                  Foreground="{StaticResource PrimaryPurpleBrush}"
                                                  Margin="5,0,0,0"/>

                                        <TextBlock Text="|"
                                                  FontSize="14"
                                                  Foreground="{StaticResource TextSecondaryBrush}"
                                                  Margin="10,0,10,0"/>

                                        <TextBlock Text="Загружено:"
                                                  FontSize="14"
                                                  Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock x:Name="UploadDateText"
                                                  Text="15.03.2024"
                                                  FontSize="14"
                                                  Foreground="{StaticResource TextPrimaryBrush}"
                                                  Margin="5,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Описание -->
                                <StackPanel Grid.Row="1"
                                           Grid.Column="1">
                                    <TextBlock Text="Описание:"
                                              FontSize="14"
                                              FontWeight="SemiBold"
                                              Foreground="{StaticResource TextSecondaryBrush}"
                                              Margin="0,0,0,5"/>
                                    <Border Background="{StaticResource DarkBackgroundBrush}"
                                            CornerRadius="10"
                                            Padding="15">
                                        <TextBlock x:Name="DescriptionText"
                                                  Text="Это потрясающее видео покажет вам красоту горных пейзажей. Снято на высоте 3000 метров над уровнем моря. В видео вы увидите восход солнца, горные реки и уникальную природу."
                                                  TextWrapping="Wrap"
                                                  FontSize="14"
                                                  Foreground="{StaticResource TextSecondaryBrush}"
                                                  LineHeight="20"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Видеоплеер -->
                        <Border Background="{StaticResource DarkBackgroundBrush}"
                                CornerRadius="15"
                                Padding="0"
                                Margin="0,0,0,20"
                                BorderBrush="{StaticResource PrimaryPurpleBrush}"
                                BorderThickness="1">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Видео -->
                                <MediaElement x:Name="VideoPlayer"
                                              Grid.Row="0"
                                              LoadedBehavior="Manual"
                                              UnloadedBehavior="Stop"
                                              Stretch="Uniform"
                                              ScrubbingEnabled="True"
                                              MediaOpened="VideoPlayer_MediaOpened"
                                              MediaEnded="VideoPlayer_MediaEnded"
                                              MediaFailed="VideoPlayer_MediaFailed"/>

                                <!-- Затемнение для кнопок -->
                                <Border Grid.Row="0"
                                        Background="#80000000"
                                        Opacity="0"
                                        IsHitTestVisible="False"
                                        x:Name="PlayerOverlay">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ElementName=VideoPlayer, Path=IsMouseOver}" Value="True">
                                                    <Setter Property="Opacity" Value="1"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>

                                <!-- Центральная кнопка Play/Pause -->
                                <Button Grid.Row="0"
                                        x:Name="PlayPauseButton"
                                        Style="{StaticResource PlayerControlButtonStyle}"
                                        Width="60"
                                        Height="60"
                                        Click="PlayPauseButton_Click"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                    <Path x:Name="PlayPausePath"
                                          Data="M0,0 L20,12 L0,24 Z"
                                          Fill="White"
                                          Width="20"
                                          Height="24"
                                          Stretch="Uniform"/>
                                </Button>

                                <!-- Панель управления -->
                                <Border Grid.Row="1"
                                        Background="#CC000000"
                                        Padding="5"
                                        CornerRadius="0,0,15,15">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Play/Pause -->
                                        <Button Grid.Column="0"
                                                x:Name="PlayPauseSmallButton"
                                                Style="{StaticResource PlayerControlButtonStyle}"
                                                Click="PlayPauseButton_Click">
                                            <Path x:Name="PlayPauseSmallPath"
                                                  Data="M0,0 L12,8 L0,16 Z"
                                                  Fill="White"
                                                  Width="12"
                                                  Height="16"
                                                  Stretch="Uniform"/>
                                        </Button>

                                        <!-- Время -->
                                        <TextBlock Grid.Column="1"
                                                   x:Name="CurrentTimeText"
                                                   Text="00:00"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"
                                                   Margin="5,0,5,0"
                                                   FontSize="12" Height="16"/>

                                        <!-- Ползунок прогресса -->
                                        <Slider Grid.Column="2"
                                                x:Name="ProgressSlider"
                                                Style="{StaticResource VideoSliderStyle}"
                                                VerticalAlignment="Center"
                                                ValueChanged="ProgressSlider_ValueChanged"
                                                PreviewMouseLeftButtonDown="ProgressSlider_PreviewMouseLeftButtonDown"
                                                PreviewMouseLeftButtonUp="ProgressSlider_PreviewMouseLeftButtonUp" Height="12" Margin="1,0,1,0"/>

                                        <!-- Общее время -->
                                        <TextBlock Grid.Column="3"
                                                   x:Name="TotalTimeText"
                                                   Text="00:00"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"
                                                   Margin="5,0,5,0"
                                                   FontSize="12" Height="16"/>

                                        <!-- Громкость -->
                                        <StackPanel Grid.Column="5"
                                                    Orientation="Horizontal">
                                            <Button x:Name="MuteButton"
                                                    Style="{StaticResource PlayerControlButtonStyle}"
                                                    Click="MuteButton_Click">
                                                <Path x:Name="VolumePath"
                                                      Data="M0,5 L5,5 L10,0 L10,15 L5,10 L0,10 Z"
                                                      Fill="White"
                                                      Width="12"
                                                      Height="16"
                                                      Stretch="Uniform"/>
                                            </Button>
                                            <Slider x:Name="VolumeSlider"
                                                    Minimum="0"
                                                    Maximum="1"
                                                    Value="0.5"
                                                    Width="80"
                                                    ValueChanged="VolumeSlider_ValueChanged"
                                                    VerticalAlignment="Center"
                                                    Margin="5,0"/>
                                        </StackPanel>

                                        <!-- Кнопка на весь экран -->
                                        <Button Grid.Column="6"
                                                x:Name="FullScreenButton"
                                                Style="{StaticResource PlayerControlButtonStyle}"
                                                Click="FullScreenButton_Click">
                                            <Image Source="pack://application:,,,/Resources/Images/FullScreen.png"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Дополнительная информация -->
                        <Border Background="{StaticResource DarkTertiaryBrush}"
                                CornerRadius="15"
                                Padding="20"
                                Margin="0,0,0,20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Статистика -->
                                <StackPanel Grid.Row="0"
                                           Grid.Column="0"
                                           Orientation="Horizontal"
                                           Margin="0,0,0,15">
                                    <Image Source="pack://application:,,,/Resources/Images/View.png" Height="20"/>
                                    <TextBlock x:Name="ViewsCountText"
                                              Text="1 234"
                                              FontSize="14"
                                              Foreground="{StaticResource TextPrimaryBrush}"
                                              Margin="10,0,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Row="0"
                                           Grid.Column="1"
                                           Orientation="Horizontal"
                                           Margin="0,0,0,15">
                                    <Image Source="pack://application:,,,/Resources/Images/Like.png" Height="20"/>
                                    <TextBlock x:Name="LikesCountText"
                                              Text="56"
                                              FontSize="14"
                                              Foreground="{StaticResource TextPrimaryBrush}"
                                              Margin="10,0,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Row="0"
                                           Grid.Column="2"
                                           Orientation="Horizontal"
                                           Margin="0,0,0,15">
                                    <Image Source="pack://application:,,,/Resources/Images/Dislike.png" Height="20"/>
                                    <TextBlock x:Name="DislikesCountText"
                                              Text="3"
                                              FontSize="14"
                                              Foreground="{StaticResource TextPrimaryBrush}"
                                              Margin="10,0,0,0"/>
                                </StackPanel>

                                <!-- Детали видео -->
                                <StackPanel Grid.Row="1"
                                           Grid.Column="0"
                                           Grid.ColumnSpan="3"
                                           Orientation="Horizontal"
                                           HorizontalAlignment="Center">

                                    <StackPanel Orientation="Horizontal" Margin="0,0,30,0">
                                        <TextBlock Text="Длительность:"
                                                  FontSize="12"
                                                  Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock x:Name="DurationText"
                                                  Text="00:00"
                                                  FontSize="12"
                                                  FontWeight="Bold"
                                                  Foreground="{StaticResource PrimaryPurpleBrush}"
                                                  Margin="5,0,0,0"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,30,0">
                                        <TextBlock Text="Разрешение:"
                                                  FontSize="12"
                                                  Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock x:Name="ResolutionText"
                                                  Text="1920x1080"
                                                  FontSize="12"
                                                  FontWeight="Bold"
                                                  Foreground="{StaticResource PrimaryPurpleBrush}"
                                                  Margin="5,0,0,0"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Формат:"
                                                  FontSize="12"
                                                  Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock x:Name="FormatText"
                                                  Text="MP4"
                                                  FontSize="12"
                                                  FontWeight="Bold"
                                                  Foreground="{StaticResource PrimaryPurpleBrush}"
                                                  Margin="5,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Комментарий при отклонении -->
                        <Border x:Name="RejectCommentBorder"
                                Background="{StaticResource DarkTertiaryBrush}"
                                CornerRadius="15"
                                Padding="20"
                                Margin="0,0,0,20"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="Причина отклонения:"
                                          FontSize="14"
                                          FontWeight="SemiBold"
                                          Foreground="{StaticResource TextSecondaryBrush}"
                                          Margin="0,0,0,10"/>
                                <TextBox x:Name="RejectCommentTextBox"
                                         Style="{StaticResource BaseTextBoxStyle}"
                                         Height="80"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         ToolTip="Укажите причину отклонения видео..."/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Кнопки действий -->
                <Border Grid.Row="2"
                        Background="{StaticResource DarkTertiaryBrush}"
                        CornerRadius="0,0,20,20"
                        Padding="20">
                    <StackPanel Orientation="Horizontal"
                              HorizontalAlignment="Center">

                        <!-- Кнопка ПРИНЯТЬ -->
                        <Button x:Name="ApproveButton"
                               Style="{StaticResource ApproveButtonStyle}"
                               Click="ApproveButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="ПРИНЯТЬ"/>
                            </StackPanel>
                        </Button>

                        <!-- Кнопка ОТКЛОНИТЬ -->
                        <Button x:Name="RejectButton"
                               Style="{StaticResource RejectButtonStyle}"
                               Click="RejectButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="ОТКЛОНИТЬ"/>
                            </StackPanel>
                        </Button>

                        <!-- Кнопка Закрыть -->
                        <Button x:Name="CancelButton"
                               Style="{StaticResource CloseButtonStyle}"
                               Click="CancelButton_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>