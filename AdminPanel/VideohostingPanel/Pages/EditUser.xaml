<Page x:Class="VideohostingPanel.Pages.EditUser"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="EditUserPage"
      MinWidth="1200" MinHeight="800"
      Background="Transparent">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/VideohostingPanel;component/Classes/Other/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <!-- Прозрачный градиентный фон для анимаций переходов -->
        <Grid x:Name="BackgroundGrid" Opacity="0.95">
            <Grid.Background>
                <RadialGradientBrush Center="0.8,0.2" RadiusX="1.2" RadiusY="1.2">
                    <GradientStop Color="#2D0B4A" Offset="0"/>
                    <GradientStop Color="#0A0A0A" Offset="1"/>
                </RadialGradientBrush>
            </Grid.Background>

            <!-- Декоративный паттерн -->
            <Rectangle Opacity="0.02">
                <Rectangle.Fill>
                    <DrawingBrush Viewport="0,0,20,20" ViewportUnits="Absolute" TileMode="Tile">
                        <DrawingBrush.Drawing>
                            <GeometryDrawing Brush="White">
                                <GeometryDrawing.Geometry>
                                    <GeometryGroup>
                                        <LineGeometry StartPoint="0,0" EndPoint="20,20"/>
                                        <LineGeometry StartPoint="20,0" EndPoint="0,20"/>
                                    </GeometryGroup>
                                </GeometryDrawing.Geometry>
                            </GeometryDrawing>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Grid>

        <!-- Основной контент с отступами -->
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Кнопка назад -->
            <Border Grid.Row="0"
                    Background="Transparent"
                    Margin="0,0,0,10"
                    HorizontalAlignment="Left">
                <Button x:Name="BackButton"
                        Style="{StaticResource BaseButtonStyle}"
                        Background="{StaticResource DarkBackgroundBrush}"
                        Width="100"
                        Height="35"
                        FontSize="12">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M0,10 L10,0 L10,20 Z"
                              Fill="{StaticResource PrimaryPurpleBrush}"
                              Width="10"
                              Height="10"
                              Margin="0,0,5,0"/>
                        <TextBlock Text="Назад"/>
                    </StackPanel>
                </Button>
            </Border>

            <!-- Контейнер для формы -->
            <Border Grid.Row="1"
                    Background="{StaticResource DarkSecondaryBrush}"
                    CornerRadius="20"
                    BorderBrush="{StaticResource PrimaryPurpleBrush}"
                    BorderThickness="1">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок -->
                    <Border Grid.Row="0"
                            Background="{StaticResource HeaderGradient}"
                            CornerRadius="20,20,0,0"
                            Height="70">
                        <TextBlock Text="Редактирование пользователя"
                                  FontSize="24"
                                  FontWeight="Bold"
                                  Foreground="White"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>

                    <!-- Форма -->
                    <ScrollViewer Grid.Row="1"
                                 Style="{StaticResource BaseScrollViewerStyle}"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="20">

                            <!-- ID пользователя -->
                            <TextBlock Text="ID"
                                      Style="{StaticResource SubHeaderStyle}"
                                      Margin="0,0,0,5"
                                      FontSize="12"/>
                            <TextBox x:Name="P_Id"
                                    Text="42"
                                    Style="{StaticResource BaseTextBoxStyle}"
                                    IsReadOnly="True"
                                    Background="{StaticResource DarkBackgroundBrush}"
                                    Margin="0,0,0,15"/>

                            <!-- Имя пользователя (Name) -->
                            <TextBlock Text="Имя пользователя *"
                                      Style="{StaticResource SubHeaderStyle}"
                                      Margin="0,0,0,5"
                                      FontSize="12"/>
                            <TextBox x:Name="P_UserNameTextBox"
                                    Text="ivan_ivanov"
                                    Style="{StaticResource BaseTextBoxStyle}"
                                    Margin="0,0,0,15"/>

                            <!-- Email -->
                            <TextBlock Text="Email *"
                                      Style="{StaticResource SubHeaderStyle}"
                                      Margin="0,0,0,5"
                                      FontSize="12"/>
                            <TextBox x:Name="P_EmailTextBox"
                                    Text="ivan@example.com"
                                    Style="{StaticResource BaseTextBoxStyle}"
                                    Margin="0,0,0,15"/>

                            <!-- Пароль (хэш и соль - только для чтения) -->
                            <TextBlock Text="Хэш пароля (SHA256)"
                                      Style="{StaticResource SubHeaderStyle}"
                                      Margin="0,0,0,5"
                                      FontSize="12"/>
                            <TextBox x:Name="P_PasswordHash"
                                    Text="a4b5c6d7e8f9..."
                                    Style="{StaticResource BaseTextBoxStyle}"
                                    Margin="0,0,0,15"/>

                            <TextBlock Text="Соль (Salt)"
                                      Style="{StaticResource SubHeaderStyle}"
                                      Margin="0,0,0,5"
                                      FontSize="12"/>
                            <TextBox x:Name="P_PasswordSalt"
                                    Text="f1e2d3c4b5a6..."
                                    Style="{StaticResource BaseTextBoxStyle}"
                                    Margin="0,0,0,15"/>

                            <!-- Статусы -->
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Статус"
                                              FontSize="12"
                                              Foreground="{StaticResource TextSecondaryBrush}"
                                              Margin="0,0,0,5"/>
                                    <CheckBox x:Name="P_IsActiveCheckBox"
                                             IsChecked="True"
                                             Content="Активен"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             FontSize="14"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Права"
                                              FontSize="12"
                                              Foreground="{StaticResource TextSecondaryBrush}"
                                              Margin="0,0,0,5"/>
                                    <CheckBox x:Name="P_CanUploadCheckBox"
                                             IsChecked="True"
                                             Content="Может загружать"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             FontSize="14"/>
                                </StackPanel>
                            </Grid>

                            <!-- Дата регистрации -->
                            <TextBlock Text="Дата регистрации"
                                      Style="{StaticResource SubHeaderStyle}"
                                      Margin="0,0,0,5"
                                      FontSize="12"/>
                            <TextBox x:Name="P_RegistrationDate"
                                    Text="01.01.2024 15:30"
                                    Style="{StaticResource BaseTextBoxStyle}"
                                    IsReadOnly="True"
                                    Background="{StaticResource DarkBackgroundBrush}"
                                    Margin="0,0,0,15"/>

                            <!-- Статистика пользователя -->
                            <Expander Header="Статистика пользователя"
                                     Background="{StaticResource DarkTertiaryBrush}"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     Margin="0,10,0,0">
                                <StackPanel Margin="10">
                                    <TextBlock x:Name="P_VideoCount"
                                              Text="Количество видео: 12"
                                              Foreground="{StaticResource TextSecondaryBrush}"
                                              Margin="0,5"/>
                                    <TextBlock x:Name="P_CommentCount"
                                              Text="Количество комментариев: 34"
                                              Foreground="{StaticResource TextSecondaryBrush}"
                                              Margin="0,5"/>
                                    <TextBlock x:Name="P_LikeCount"
                                              Text="Количество лайков: 56"
                                              Foreground="{StaticResource TextSecondaryBrush}"
                                              Margin="0,5"/>
                                </StackPanel>
                            </Expander>

                            <!-- Кнопка удалить (в стиле как в EditCommentPage) -->
                            <Border Background="{StaticResource DarkTertiaryBrush}"
                                    CornerRadius="14"
                                    Margin="0,20,0,0"
                                    Padding="20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="1"
                                           x:Name="P_DeleteButton"
                                           Content="УДАЛИТЬ ПОЛЬЗОВАТЕЛЯ"
                                           Background="#66FF0000"
                                           Style="{StaticResource BaseButtonStyle}"
                                           Width="250"
                                           Height="45"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Кнопки действий -->
                    <Border Grid.Row="2"
                            Background="{StaticResource DarkTertiaryBrush}"
                            CornerRadius="0,0,20,20"
                            Padding="20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="1"
                                   x:Name="P_SaveButton"
                                   Content="Сохранить"
                                   Style="{StaticResource BaseButtonStyle}"
                                   Width="120"
                                   Margin="10"/>
                            <Button Grid.Column="2"
                                   x:Name="P_CancelButton"
                                   Content="Отмена"
                                   Style="{StaticResource BaseButtonStyle}"
                                   Background="{StaticResource DarkBackgroundBrush}"
                                   Width="120"
                                   Margin="10"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Нижний отступ для баланса -->
            <Border Grid.Row="2" Height="10" Background="Transparent"/>
        </Grid>
    </Grid>
</Page>