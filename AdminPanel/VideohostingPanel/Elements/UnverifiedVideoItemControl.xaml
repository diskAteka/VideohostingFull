<UserControl x:Class="VideohostingPanel.Elements.UnverifiedVideoItemControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" MouseUp="GoVerify">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/VideohostingPanel;component/Classes/Other/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Стиль для кнопок действий -->
            <Style x:Key="ActionButtonStyle" BasedOn="{StaticResource BaseButtonStyle}" TargetType="Button">
                <Setter Property="Height" Value="35"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Margin" Value="5,0,0,0"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- Основной контейнер - Border с одним дочерним элементом Grid -->
    <Border Background="{StaticResource DarkTertiaryBrush}"
            CornerRadius="15"
            Margin="0,0,0,15"
            BorderBrush="{StaticResource PrimaryRedBrush}"
            BorderThickness="2"
            Cursor="Hand"
            RenderTransformOrigin="0.5,0.5">

        <!-- Стиль с триггерами для анимации (вместо Border.Triggers) -->
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Trigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Duration="0:0:0.2"
                                                   Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                   To="1.01"/>
                                    <DoubleAnimation Duration="0:0:0.2"
                                                   Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                   To="1.01"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>
                        <Trigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Duration="0:0:0.2"
                                                   Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                   To="1"/>
                                    <DoubleAnimation Duration="0:0:0.2"
                                                   Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                   To="1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.ExitActions>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <!-- Единственный дочерний элемент - Grid -->
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Постер (превью) - вложенный Border, это не Child основного Border, а элемент Grid -->
            <Border Grid.Row="0"
                    Grid.RowSpan="3"
                    Grid.Column="0"
                    Width="100"
                    Height="80"
                    Background="{StaticResource DarkBackgroundBrush}"
                    CornerRadius="10"
                    Margin="0,0,15,0">
                <Grid>
                    <Path Data="M0,0 L40,0 L40,30 L0,30 Z M5,5 L35,5 L35,25 L5,25 Z"
                          Fill="{StaticResource PrimaryRedBrush}"
                          Width="40"
                          Height="30"
                          Stretch="Uniform"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
                    <Border Background="#80000000"
                            CornerRadius="10"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Bottom"
                            Height="25">
                        <TextBlock Text="HD"
                                  Foreground="White"
                                  FontSize="10"
                                  FontWeight="Bold"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Название видео и автор -->
            <StackPanel Grid.Row="0"
                       Grid.Column="1"
                       Margin="0,0,0,5">
                <TextBlock x:Name="VideoNameText"
                          Text="Название видео"
                          FontSize="18"
                          FontWeight="Bold"
                          Foreground="{StaticResource TextPrimaryBrush}"/>

                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <TextBlock Text="Автор:"
                              FontSize="12"
                              Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock x:Name="AuthorNameText"
                              Text="Иван Иванов"
                              FontSize="12"
                              FontWeight="Bold"
                              Foreground="{StaticResource PrimaryPurpleBrush}"
                              Margin="5,0,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- Дата загрузки и ID -->
            <StackPanel Grid.Row="0"
                       Grid.Column="2"
                       Orientation="Horizontal"
                       VerticalAlignment="Top"
                       Margin="0,0,15,0">
                <Path Data="M0,0 L10,0 L10,10 L0,10 Z M2,2 L8,2 L8,8 L2,8 Z"
                      Stroke="{StaticResource TextSecondaryBrush}"
                      StrokeThickness="1"
                      Fill="Transparent"
                      Width="14"
                      Height="14"/>
                <TextBlock x:Name="UploadDateText"
                          Text="01.01.2024"
                          FontSize="12"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          Margin="5,0,0,0"/>
            </StackPanel>

            <!-- ID видео -->
            <TextBlock x:Name="VideoIdText"
                        Grid.Row="0"
                        Grid.Column="3"
                        Text="#12345"
                        FontSize="12"
                        FontWeight="Bold"
                        Foreground="{StaticResource TextSecondaryBrush}"/>

            <!-- Описание видео -->
            <Border Grid.Row="1"
                    Grid.Column="1"
                    Grid.ColumnSpan="3"
                    Background="{StaticResource DarkBackgroundBrush}"
                    CornerRadius="10"
                    Padding="12,8"
                    Margin="0,5,0,10">
                <TextBlock x:Name="DescriptionText"
                          Text="Описание видео. Здесь может быть краткое описание контента, которое загрузил автор..."
                          TextWrapping="Wrap"
                          FontSize="12"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          MaxHeight="40"/>
            </Border>
        </Grid>
    </Border>
</UserControl>