<UserControl x:Class="VideohostingPanel.Elements.CommentItemControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MouseUp="GoChangeRecord">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/VideohostingPanel;component/Classes/Other/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="{StaticResource DarkTertiaryBrush}"
            CornerRadius="15"
            Margin="0,0,0,15"
            BorderBrush="{StaticResource PrimaryPurpleBrush}"
            BorderThickness="1"
            Cursor="Hand">

        <Border.Triggers>
            <EventTrigger RoutedEvent="Border.MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Duration="0:0:0.2"
                                       Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                       To="1.02"/>
                        <DoubleAnimation Duration="0:0:0.2"
                                       Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                       To="1.02"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="Border.MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Duration="0:0:0.2"
                                       Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                       To="1"/>
                        <DoubleAnimation Duration="0:0:0.2"
                                       Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                       To="1"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>

        <Border.RenderTransform>
            <ScaleTransform ScaleX="1" ScaleY="1"/>
        </Border.RenderTransform>

        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Аватар пользователя -->
            <Border Grid.Row="0"
                    Grid.RowSpan="2"
                    Grid.Column="0"
                    Width="50"
                    Height="50"
                    Background="{StaticResource DarkBackgroundBrush}"
                    CornerRadius="25"
                    Margin="0,0,15,0">
                <Path Data="M0,25 A25,25 0 0 1 50,25 M0,25 A25,25 0 0 0 50,25 M25,12 A8,8 0 0 0 25,28 A8,8 0 0 0 25,12"
                      Stroke="{StaticResource PrimaryPurpleBrush}"
                      StrokeThickness="2"
                      Fill="Transparent"
                      Width="30"
                      Height="30"
                      Stretch="Uniform"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"/>
            </Border>

            <!-- Верхняя строка: автор и дата -->
            <StackPanel Grid.Row="0"
                       Grid.Column="1"
                       Orientation="Horizontal"
                       Margin="0,0,0,5">
                <TextBlock x:Name="AuthorNameText"
                          Text="Иван Иванов"
                          FontSize="14"
                          FontWeight="Bold"
                          Foreground="{StaticResource TextPrimaryBrush}"/>

                <TextBlock Text="комментирует"
                          FontSize="12"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          Margin="5,0,5,0"/>

                <TextBlock x:Name="VideoNameText"
                          Text="Название видео"
                          FontSize="12"
                          FontWeight="SemiBold"
                          Foreground="{StaticResource PrimaryPurpleBrush}"/>
            </StackPanel>

            <!-- Дата комментария -->
            <StackPanel Grid.Row="0"
                       Grid.Column="2"
                       Orientation="Horizontal"
                       VerticalAlignment="Center">
                <Path Data="M0,0 L10,0 L10,10 L0,10 Z M2,2 L8,2 L8,8 L2,8 Z"
                      Stroke="{StaticResource TextSecondaryBrush}"
                      StrokeThickness="1"
                      Fill="Transparent"
                      Width="12"
                      Height="12"/>
                <TextBlock x:Name="CommentDateText"
                          Text="01.01.2024 15:30"
                          FontSize="11"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          Margin="5,0,0,0"/>
            </StackPanel>

            <!-- Текст комментария -->
            <Border Grid.Row="1"
                    Grid.Column="1"
                    Grid.ColumnSpan="2"
                    Background="{StaticResource DarkBackgroundBrush}"
                    CornerRadius="10"
                    Padding="12,8"
                    Margin="0,5,0,0">
                <TextBlock x:Name="CommentText"
                          Text="Текст комментария пользователя о видео. Здесь может быть достаточно длинный текст, который нужно отобразить полностью или обрезать..."
                          TextWrapping="Wrap"
                          FontSize="12"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          MaxHeight="60"/>
            </Border>
        </Grid>
    </Border>
</UserControl>