<UserControl x:Class="VideohostingPanel.Elements.LogItemControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/VideohostingPanel;component/Classes/Other/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="{StaticResource DarkTertiaryBrush}"
            CornerRadius="15"
            Margin="0,0,0,15"
            BorderBrush="{StaticResource PrimaryPurpleBrush}"
            BorderThickness="1"
            Cursor="Hand"
            Opacity="0.9">

        <Border.Triggers>
            <EventTrigger RoutedEvent="Border.MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Duration="0:0:0.2"
                                       Storyboard.TargetProperty="Opacity"
                                       To="1"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="Border.MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Duration="0:0:0.2"
                                       Storyboard.TargetProperty="Opacity"
                                       To="0.9"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>

        <Grid Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Иконка типа события -->
            <Border Grid.Column="0"
                    Width="50"
                    Height="50"
                    Background="{StaticResource DarkBackgroundBrush}"
                    CornerRadius="10"
                    Margin="0,0,15,0">
                <Path x:Name="TypeIcon"
                      Data="M0,0 L20,0 L20,20 L0,20 Z M2,2 L18,2 L18,18 L2,18 Z"
                      Fill="{StaticResource PrimaryPurpleBrush}"
                      Width="25"
                      Height="25"
                      Stretch="Uniform"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"/>
            </Border>

            <!-- Информация о событии -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="EventTypeText"
                              Text="Вход в систему"
                              FontSize="14"
                              FontWeight="Bold"
                              Foreground="{StaticResource TextPrimaryBrush}"/>

                    <Border x:Name="EventTypeBadge"
                            Background="#338A2BE2"
                            CornerRadius="8"
                            Padding="6,2"
                            Margin="10,0,0,0">
                        <TextBlock x:Name="EventTypeCodeText"
                                  Text="INFO"
                                  FontSize="9"
                                  FontWeight="Bold"
                                  Foreground="#FFB794FF"/>
                    </Border>
                </StackPanel>

                <TextBlock x:Name="UserInfoText"
                          Text="Пользователь: admin_user"
                          FontSize="12"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Дата и время -->
            <StackPanel Grid.Column="2" 
                       Orientation="Horizontal"
                       VerticalAlignment="Center"
                       Margin="0,0,15,0">
                <Path Data="M0,0 L10,0 L10,10 L0,10 Z M2,2 L8,2 L8,8 L2,8 Z"
                      Stroke="{StaticResource TextSecondaryBrush}"
                      StrokeThickness="1"
                      Fill="Transparent"
                      Width="14"
                      Height="14"/>
                <TextBlock x:Name="EventDateText"
                          Text="01.01.2024"
                          FontSize="11"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          Margin="5,0,5,0"/>
                <TextBlock x:Name="EventTimeText"
                          Text="15:30:45"
                          FontSize="11"
                          FontWeight="Bold"
                          Foreground="{StaticResource PrimaryRedBrush}"/>
            </StackPanel>

            <!-- ID записи -->
            <TextBlock x:Name="LogIdText" Grid.Column="3"
                       Text="#12345"
                       FontSize="11"
                       VerticalAlignment="Center"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
        </Grid>
    </Border>
</UserControl>