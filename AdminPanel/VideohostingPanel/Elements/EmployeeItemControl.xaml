<UserControl x:Class="VideohostingPanel.Elements.EmployeeItemControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" MouseUp="GoChangeRecord">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/VideohostingPanel;component/Classes/Other/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- Основной контейнер - Border с одним дочерним элементом -->
    <Border Background="{StaticResource DarkTertiaryBrush}"
            CornerRadius="15"
            Margin="0,0,0,15"
            BorderBrush="{StaticResource PrimaryPurpleBrush}"
            BorderThickness="1"
            Cursor="Hand"
            RenderTransformOrigin="0.5,0.5">

        <!-- Стиль с триггерами вместо Border.Triggers -->
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Trigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Duration="0:0:0.2"
                                                   Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                   To="1.02"/>
                                    <DoubleAnimation Duration="0:0:0.2"
                                                   Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                   To="1.02"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>
                        <Trigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Duration="0:0:0.2"
                                                   Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                   To="1"/>
                                    <DoubleAnimation Duration="0:0:0.2"
                                                   Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                   To="1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.ExitActions>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <!-- Единственный дочерний элемент - Grid -->
        <Grid Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Иконка сотрудника - здесь Border содержит Grid с двумя элементами -->
            <Border Grid.Column="0"
                    Width="60"
                    Height="60"
                    Background="{StaticResource DarkBackgroundBrush}"
                    CornerRadius="30"
                    Margin="0,0,15,0">
                <Grid>
                    <!-- Основная иконка (силуэт) -->
                    <Path Data="M0,30 A30,30 0 0 1 60,30 M0,30 A30,30 0 0 0 60,30 M30,10 A10,10 0 0 0 30,30 A10,10 0 0 0 30,10"
                          Stroke="{StaticResource PrimaryPurpleBrush}"
                          StrokeThickness="2"
                          Fill="Transparent"
                          Width="40"
                          Height="40"
                          Stretch="Uniform"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>

                    <!-- Значок роли - отдельный Border внутри того же Grid -->
                    <!-- Красный значок с буквой A -->
                    <Border x:Name="RoleIconABorder"
                            Background="{StaticResource PrimaryRedBrush}"
                            CornerRadius="10"
                            Width="20"
                            Height="20"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            BorderBrush="{StaticResource DarkBackgroundBrush}"
                            BorderThickness="2">
                        <TextBlock x:Name="RoleIconAText"
                                  Text="A"
                                  FontSize="10"
                                  FontWeight="Bold"
                                  Foreground="White"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>

                    <!-- Желтый значок с буквой V (изначально скрыт) -->
                    <Border x:Name="RoleIconVBorder"
                            Background="Gold"
                            CornerRadius="10"
                            Width="20"
                            Height="20"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            BorderBrush="{StaticResource DarkBackgroundBrush}"
                            BorderThickness="2"
                            Visibility="Collapsed">
                        <TextBlock x:Name="RoleIconVText"
                                  Text="V"
                                  FontSize="10"
                                  FontWeight="Bold"
                                  Foreground="White"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Информация о сотруднике -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <!-- ID сотрудника -->
                <TextBlock x:Name="EmployeeIdText"
                          Text="ID: 12345"
                          FontSize="12"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          Margin="0,0,0,5"/>

                <!-- Логин -->
                <TextBlock x:Name="EmployeeLoginText"
                          Text="Логин: admin_ivan"
                          FontSize="14"
                          FontWeight="Bold"
                          Foreground="{StaticResource TextPrimaryBrush}"/>

                <!-- Пароль (без сокрытия) -->
                <TextBlock x:Name="EmployeePasswordText"
                          Text="Пароль: Qwerty123"
                          FontSize="12"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          Margin="0,5,0,5"/>

                <!-- Роль -->
                <Border x:Name="RoleBadge"
                        Background="#338A2BE2"
                        CornerRadius="10"
                        Padding="8,3"
                        Margin="0,0,0,0"
                        HorizontalAlignment="Left">
                    <TextBlock x:Name="RoleText"
                              Text="Admin"
                              FontSize="10"
                              FontWeight="Bold"
                              Foreground="#FFB794FF"/>
                </Border>
            </StackPanel>

            <!-- Свободное место справа (можно использовать для будущих элементов) -->
            <StackPanel Grid.Column="2" 
                       Orientation="Horizontal"
                       VerticalAlignment="Center"
                       MinWidth="80">
                <!-- Пустой контейнер для будущего использования -->
            </StackPanel>
        </Grid>
    </Border>
</UserControl>