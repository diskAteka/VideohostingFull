<UserControl x:Class="VideohostingPanel.Elements.ViewItemControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/VideohostingPanel;component/Classes/Other/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="{StaticResource DarkTertiaryBrush}"
            CornerRadius="15"
            Margin="0,0,0,15"
            BorderBrush="{StaticResource PrimaryPurpleBrush}"
            BorderThickness="1"
            Cursor="Hand">

        <Border.Triggers>
            <EventTrigger RoutedEvent="Border.MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Duration="0:0:0.2"
                                       Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                       To="1.02"/>
                        <DoubleAnimation Duration="0:0:0.2"
                                       Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                       To="1.02"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="Border.MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Duration="0:0:0.2"
                                       Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                       To="1"/>
                        <DoubleAnimation Duration="0:0:0.2"
                                       Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                       To="1"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>

        <Border.RenderTransform>
            <ScaleTransform ScaleX="1" ScaleY="1"/>
        </Border.RenderTransform>

        <Grid Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Иконка просмотра -->
            <Border Grid.Column="0"
                    Width="50"
                    Height="50"
                    Background="{StaticResource DarkBackgroundBrush}"
                    CornerRadius="10"
                    Margin="0,0,15,0">
                <Path Data="M0,5 C2,0 8,0 10,5 C8,10 2,10 0,5"
                      Stroke="{StaticResource PrimaryPurpleBrush}"
                      StrokeThickness="2"
                      Fill="Transparent"
                      Width="25"
                      Height="15"
                      Stretch="Uniform"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"/>
            </Border>

            <!-- Информация о просмотре -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Просмотр"
                              FontSize="14"
                              FontWeight="Bold"
                              Foreground="{StaticResource TextPrimaryBrush}"/>

                    <TextBlock Text="видео"
                              FontSize="12"
                              Foreground="{StaticResource TextSecondaryBrush}"
                              Margin="5,0,5,0"/>

                    <TextBlock x:Name="VideoNameText"
                              Text="Название видео"
                              FontSize="12"
                              FontWeight="SemiBold"
                              Foreground="{StaticResource PrimaryPurpleBrush}"/>
                </StackPanel>

                <TextBlock x:Name="UserInfoText"
                          Text="Пользователь: Иван Иванов"
                          FontSize="12"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          Margin="0,5,0,0"/>
            </StackPanel>

            <!-- ID просмотра -->
            <TextBlock x:Name="ViewIdText"
                       Grid.Column="2"
                       Text="#12345"
                       VerticalAlignment="Center"
                       FontSize="11"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,10,0"/>

            <!-- Кнопка удаления -->
            <Button Grid.Column="3"
                    Width="30"
                    Height="30"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    VerticalAlignment="Center">
                <Path Data="M0,0 L10,10 M10,0 L0,10"
                      MouseUp="DeleteView"
                      Stroke="{StaticResource PrimaryRedBrush}"
                      StrokeThickness="2"
                      Width="12"
                      Height="12"
                      Stretch="Uniform"/>
            </Button>
        </Grid>
    </Border>
</UserControl>