<UserControl x:Class="VideohostingPanel.Elements.UserItemControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MouseUp="GoChangeRecord">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/VideohostingPanel;component/Classes/Other/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="{StaticResource DarkTertiaryBrush}"
            CornerRadius="15"
            Margin="0,0,0,15"
            BorderBrush="{StaticResource PrimaryPurpleBrush}"
            BorderThickness="1"
            Cursor="Hand"
            RenderTransformOrigin="0.5,0.5">

        <!-- Убраны EventTrigger из Border.Triggers (они не поддерживаются напрямую) 
             и заменены на триггеры стиля -->
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Trigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Duration="0:0:0.2"
                                                   Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                   To="1.02"/>
                                    <DoubleAnimation Duration="0:0:0.2"
                                                   Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                   To="1.02"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>
                        <Trigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Duration="0:0:0.2"
                                                   Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                   To="1"/>
                                    <DoubleAnimation Duration="0:0:0.2"
                                                   Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                   To="1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.ExitActions>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Аватар (иконка) -->
            <Border Grid.Column="0"
                    Width="60"
                    Height="60"
                    Background="{StaticResource DarkBackgroundBrush}"
                    CornerRadius="30"
                    Margin="0,0,15,0">
                <Path Data="M0,30 A30,30 0 0 1 60,30 M0,30 A30,30 0 0 0 60,30 M30,15 A10,10 0 0 0 30,35 A10,10 0 0 0 30,15"
                      Stroke="{StaticResource PrimaryPurpleBrush}"
                      StrokeThickness="2"
                      Fill="Transparent"
                      Width="40"
                      Height="40"
                      Stretch="Uniform"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"/>
            </Border>

            <!-- Информация о пользователе -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock x:Name="UserNameText"
                          Text="Иван Иванов"
                          FontSize="16"
                          FontWeight="Bold"
                          Foreground="{StaticResource TextPrimaryBrush}"/>

                <TextBlock x:Name="UserEmailText"
                          Text="ivan@example.com"
                          FontSize="12"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          Margin="0,5,0,0"/>

                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <!-- Статус активности -->
                    <Border x:Name="ActiveBadge"
                            Background="#3300FF00"
                            CornerRadius="10"
                            Padding="8,3">
                        <TextBlock x:Name="ActiveText"
                                  Text="Активен"
                                  FontSize="10"
                                  FontWeight="Bold"
                                  Foreground="#FF88FF88"/>
                    </Border>

                    <!-- Права на загрузку -->
                    <Border x:Name="UploadBadge"
                            Background="#338A2BE2"
                            CornerRadius="10"
                            Padding="8,3"
                            Margin="10,0,0,0">
                        <TextBlock x:Name="UploadText"
                                  Text="Может загружать"
                                  FontSize="10"
                                  FontWeight="Bold"
                                  Foreground="#FFB794FF"/>
                    </Border>
                </StackPanel>
            </StackPanel>

            <!-- Дата регистрации -->
            <StackPanel Grid.Column="2" 
                       Orientation="Horizontal"
                       VerticalAlignment="Center"
                       Margin="0,0,15,0">
                <Path Data="M0,0 L10,0 L10,10 L0,10 Z M2,2 L8,2 L8,8 L2,8 Z"
                      Stroke="{StaticResource TextSecondaryBrush}"
                      StrokeThickness="1"
                      Fill="Transparent"
                      Width="14"
                      Height="14"/>
                <TextBlock x:Name="RegisteredDateText"
                          Text="01.01.2024"
                          FontSize="12"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          Margin="5,0,0,0"/>
            </StackPanel>

            <!-- ID пользователя -->
            <TextBlock x:Name="UserIdText"
                       Grid.Column="3"
                       Text="#12345"
                       VerticalAlignment="Center"
                       FontSize="11"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
        </Grid>
    </Border>
</UserControl>