<UserControl x:Class="VideohostingPanel.Elements.DislikeItemControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/VideohostingPanel;component/Classes/Other/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="{StaticResource DarkTertiaryBrush}"
            CornerRadius="15"
            Margin="0,0,0,15"
            BorderBrush="{StaticResource PrimaryPurpleBrush}"
            BorderThickness="1"
            Cursor="Hand">

        <Border.Triggers>
            <EventTrigger RoutedEvent="Border.MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Duration="0:0:0.2"
                                       Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                       To="1.02"/>
                        <DoubleAnimation Duration="0:0:0.2"
                                       Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                       To="1.02"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="Border.MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Duration="0:0:0.2"
                                       Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                       To="1"/>
                        <DoubleAnimation Duration="0:0:0.2"
                                       Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                       To="1"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>

        <Border.RenderTransform>
            <ScaleTransform ScaleX="1" ScaleY="1"/>
        </Border.RenderTransform>

        <Grid Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Иконка дизлайка -->
            <Border Grid.Column="0"
                    Width="50"
                    Height="50"
                    Background="{StaticResource DarkBackgroundBrush}"
                    CornerRadius="25"
                    Margin="0,0,15,0">
                <Path x:Name="DislikeIcon"
                      Data="M0,5 L5,10 L10,5 L5,0 L0,5"
                      Fill="{StaticResource TextSecondaryBrush}"
                      Width="20"
                      Height="20"
                      Stretch="Uniform"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"/>
            </Border>

            <!-- Информация о дизлайке -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="DislikeTypeText"
                              Text="Дизлайк"
                              FontSize="14"
                              FontWeight="Bold"
                              Foreground="{StaticResource TextSecondaryBrush}"/>

                    <TextBlock Text="от"
                              FontSize="12"
                              Foreground="{StaticResource TextSecondaryBrush}"
                              Margin="5,0,5,0"/>

                    <TextBlock x:Name="UserNameText"
                              Text="Иван Иванов"
                              FontSize="12"
                              FontWeight="SemiBold"
                              Foreground="{StaticResource PrimaryPurpleBrush}"/>
                </StackPanel>

                <TextBlock x:Name="VideoNameText"
                          Text="Видео: Название видео"
                          FontSize="12"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          Margin="0,5,0,0"/>
            </StackPanel>

            <!-- ID записи (для информации) -->
            <TextBlock Grid.Column="2"
                      x:Name="ReactionIdText"
                      Text="#12345"
                      FontSize="11"
                      Foreground="{StaticResource TextSecondaryBrush}"
                      VerticalAlignment="Center"
                      Margin="0,0,10,0"/>

            <!-- Кнопка удаления -->
            <Button Grid.Column="3" MouseUp="DeleteDislike"
                    Width="30"
                    Height="30"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    VerticalAlignment="Center">
                <Path Data="M0,0 L10,10 M10,0 L0,10"
                      Stroke="{StaticResource PrimaryRedBrush}"
                      StrokeThickness="2"
                      Width="12"
                      Height="12"
                      Stretch="Uniform"/>
            </Button>
        </Grid>
    </Border>
</UserControl>